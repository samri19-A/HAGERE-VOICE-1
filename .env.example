VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin portal setup (Supabase Dashboard → SQL Editor):
# 1. Run supabase/migrations/master.sql  (or 004_admin_roles.sql if schema exists)
# 2. Authentication → Users → Add user with email/password, Auto Confirm ON
# 3. Run supabase/setup_admin.sql to grant the admin role